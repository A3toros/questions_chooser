{
  "name": "vocabform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "concurrently -k -n api,vite -c cyan,green \"npm run dev:api\" \"npm run dev:vite\"",
    "dev:vite": "vite --port 5175",
    "dev:api": "tsx server/dev.ts",
    "dev:netlify": "netlify dev",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@netlify/functions": "^2.8.2",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.62.8",
    "framer-motion": "^11.15.0",
    "heic2any": "^0.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "netlify-cli": "^18.0.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  }
}
